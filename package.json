{
  "name": "wenmei",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "desktop:build": "tauri build",
    "desktop:build:win": "tauri build --target x86_64-pc-windows-msvc",
    "desktop:build:mac": "tauri build --target aarch64-apple-darwin --bundles app && scripts/build-dmg-mac.sh aarch64",
    "desktop:build:mac:intel": "tauri build --target x86_64-apple-darwin --bundles app && scripts/build-dmg-mac.sh x86_64",
    "desktop:build:mac:all": "npm run desktop:build:mac && npm run desktop:build:mac:intel",
    "desktop:build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "check": "tsc -b",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "pb:status": "node scripts/pb.mjs status",
    "pb:next": "node scripts/pb.mjs next",
    "pb:record": "node scripts/pb.mjs record",
    "pb:report": "node scripts/pb.mjs report",
    "pb:validate": "node scripts/pb.mjs validate",
    "pb:init": "node scripts/pb.mjs init"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.4.8",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.16"
  }
}
