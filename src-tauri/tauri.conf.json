{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Wenmei",
  "version": "0.1.0",
  "identifier": "com.wenmei.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Wenmei",
        "width": 1400,
        "height": 900,
        "minWidth": 600,
        "minHeight": 400,
        "center": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": []
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../scripts/wenmei",
      "../scripts/install.sh",
      "../scripts/install-cli.sh",
      "../scripts/install-finder-service.sh",
      "../scripts/install-quicklook.sh",
      "../scripts/verify.sh"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "contentTypes": [
          "net.daringfireball.markdown",
          "public.markdown",
          "public.plain-text"
        ],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown",
        "rank": "Default"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
